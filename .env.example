SESSION_ENCRYPT=false

CACHE_STORE=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@ascent.in"
MAIL_FROM_NAME="${APP_NAME}"

# Admin panel: http://localhost:8000/admin
